# Sélection de l'environnement Django
DJANGO_SETTINGS_MODULE=backend.settings.production

# ============================================================
# Template .env de PRODUCTION — EthniSpirit
# Copier en ".env" sur le serveur LWS (dans backend/)
# NE JAMAIS committer le vrai .env dans git
# ============================================================

# Clé secrète Django — générer sur : https://djecrety.ir/
SECRET_KEY=remplacer-par-une-cle-secrete-longue-et-aleatoire

# Base de données PostgreSQL LWS
# (cPanel > PostgreSQL Databases)
DB_NAME=VOTRE_LOGIN_ethnispirit
DB_USER=VOTRE_LOGIN_ethniuser
DB_PASSWORD=MOT_DE_PASSE_DB
DB_HOST=localhost
DB_PORT=5432

# URL du frontend — utilisée dans les emails (liens de suivi, reset, etc.)
FRONTEND_URL=https://ethnispirit.com

# Email LWS — port 465 SSL
# (cPanel > Email Accounts > contact@ethnispirit.com)
EMAIL_HOST=mail.ethnispirit.com
EMAIL_PORT=465
EMAIL_HOST_USER=contact@ethnispirit.com
EMAIL_HOST_PASSWORD=MOT_DE_PASSE_EMAIL
DEFAULT_FROM_EMAIL=EthniSpirit <contact@ethnispirit.com>

# Stripe — remplacer par les clés live quand le compte est validé
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_STRIPE_SECRETE
STRIPE_PUBLISHABLE_KEY=pk_test_VOTRE_CLE_STRIPE_PUBLIQUE
